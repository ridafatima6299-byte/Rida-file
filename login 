<!DOCTYPE html>
<html>
<head>
    <title>Simple Aesthetic Login</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #a8edea, #fed6e3);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 300px;
            text-align: center;
        }

        .login-box h2 {
            margin-bottom: 20px;
            color: #333;
        }

        .input-box {
            margin: 15px 0;
        }

        .input-box input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            outline: none;
        }

        .login-btn {
            margin-top: 20px;
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: #6c63ff;
            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        .login-btn:hover {
            background: #574fd6;
        }

        /* Hidden Map Section */
        #map {
            display: none;
            margin-top: 20px;
        }

        #show-map:checked ~ #map {
            display: block;
        }

        .toggle-label {
            display: block;
            margin-top: 15px;
            color: #6c63ff;
            cursor: pointer;
            font-size: 14px;
        }

        iframe {
            width: 100%;
            height: 200px;
            border-radius: 10px;
            border: none;
        }

    </style>
</head>
<body>

<div class="login-box">
    <h2>Login</h2>

    <div class="input-box">
        <input type="text" placeholder="Username">
    </div>

    <div class="input-box">
        <input type="password" placeholder="Password">
    </div>

    <button class="login-btn">Sign In</button>

    <!-- Hidden Map Toggle -->
    <input type="checkbox" id="show-map" hidden>
    <label for="show-map" class="toggle-label">Show Location</label>

    <div id="map">
        <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.019315341226!2d-122.41941518468164!3d37.77492977975961!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8085809c5c3f1fdf%3A0x4d3a6a0eef89441f!2sSan%20Francisco!5e0!3m2!1sen!2sus!4v1616581098765">
        </iframe>
    </div>

</div>

</body>
</html>
